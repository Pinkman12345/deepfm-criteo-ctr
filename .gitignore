# =========================
# Python cache
# =========================
__pycache__/
*.py[cod]
*$py.class

# =========================
# Virtual environments
# =========================
.venv/
venv/
env/

# =========================
# Jupyter / notebooks
# =========================
.ipynb_checkpoints/

# =========================
# VS Code / IDE
# =========================
.vscode/
.idea/

# =========================
# OS files
# =========================
.DS_Store
Thumbs.db

# =========================
# Logs
# =========================
*.log

# =========================
# Model files
# =========================
outputs/models/*.pth
outputs/models/*.pt
outputs/models/*.joblib
outputs/models/*.pkl

# =========================
# Large raw / processed data
# =========================
data/raw/*.csv
data/processed/*.csv

# Optional: ignore all files but keep folder structure
# data/raw/*
# !data/raw/.gitkeep
# data/processed/*
# !data/processed/.gitkeep

# =========================
# Python packaging
# =========================
build/
dist/
*.egg-info/

# =========================
# Testing / coverage
# =========================
.pytest_cache/
.coverage
htmlcov/